# ─── Application ───
APP_NAME=Canopy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ─── Logging ───
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ───
# Dev: sqlite | Prod: pgsql
DB_CONNECTION=sqlite
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=canopy
# DB_USERNAME=canopy
# DB_PASSWORD=secret

# ─── Session ───
# Dev: file | Prod: redis
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting ───
BROADCAST_CONNECTION=reverb

# ─── Filesystem ───
# Dev: local | Prod: s3 (MinIO)
FILESYSTEM_DISK=local

# ─── Queue ───
# Dev: sync | Prod: redis
QUEUE_CONNECTION=sync

# ─── Cache ───
# Dev: array | Prod: redis
CACHE_STORE=array
CACHE_PREFIX=canopy_

# ─── Redis ───
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Reverb (WebSocket) ───
REVERB_APP_ID=canopy-local
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080

# ─── MinIO / File Storage ───
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=canopy-files
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Mail ───
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@canopy.test"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Vite ───
VITE_APP_NAME="${APP_NAME}"
